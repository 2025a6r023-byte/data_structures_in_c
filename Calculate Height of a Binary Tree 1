#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
int height(int *tree,int index,int n){
    if(index >= n|| tree[index] == -1)
        return -1;
    int left = height(tree, 2*index+1,n);
    int right = height(tree, 2*index+2,n);
    int max = left > right ? left : right;
    return max+1;
}
int main() {
    int n;
    scanf("%d",&n);
    int tree[n];
    for(int i=0; i<n; i++){
        scanf("%d",&tree[i]);
    }
    int h = height(tree ,0,n);
    printf("%d",h);
    return 0;
}
