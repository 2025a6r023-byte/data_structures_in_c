#include<stdio.h>
#include<stdlib.h>
#define MAX 100
int list[MAX];
int n =0;
int data;
int pos;

void insertInBeg(int value){
    if(n>= MAX){
        printf("list is full!!\n");
        return ;
    }
    int i;
    for( i = n; i>0 ; i++){
        list[i] = list[i-1];
    }
    list[i] = value;
    n++;
    printf("Element inserted in beginning!!\n");
}
void insertAtEnd(int value){
    if(n == MAX){
        printf("list is full!!\n");
        return ;
    }
    list[n++] = value;
    printf("Element inserted !!\n");
}
void insertAtPosition(int pos, int value){
    if(n == MAX)
        printf("list is full!!\n");
    else if(pos < 0 || pos >= n)
        printf("invalid position!!\n");
    else{
        for(int i=n-1 ;i>=pos ;i--){
            list[i+1]=list[i];
        }
        list[pos]=value;
        n++;
        printf("element inserted !!\n");
    }
}
void deleteFromBeg(){
    if(n == 0){
        printf("list is empty!!\n");
        return;
    }
    for(int i=0; i<=n; i++){
        list[i]=list[i+1];
    }
    n--;
    printf("element deleted!!\n");
}
void deleteFromEnd(){
    if(n == 0){
        printf("list is empty!!\n");
        return;
    }
    n--;
    printf("element deleted!!!\n");
}
void deleteAtPosition(int pos){
    if(n == 0)
       printf("list is empty!!\n");
    else if(pos<0 || pos>=n)
       printf("invalid position!!\n");
    else{
        for(int i=pos; i<n; i++){
            list[i] = list[i+1];
        }
        n--;
        printf("element deleted!!\n");
    }
}
int search(int value){
    for(int i=0; i<n; i++){
        if(list[i]==value)
            return i;
    }
    return -1;
}
void updatelist(int pos, int value){
    if(n==0)
      printf("list is empty!!\n");
    else if(pos<0 || pos>=n)
    printf("invalid position!!\n");
    else{
        list[pos]=value;
        printf("element updated!!\n");
    }

}
void bubblesort(){
    for(int i=0; i<n-1; i++){
        for(int j=0; j<n-i-1; j++){
            if(list[j] > list[j+1]){
                int temp = list[j+1];
                list[j] = list[j+1];
                list[j+1] = temp;
            }
        }
    }
    printf("element sorted!!\n");
}
void displaylist(){
    if(n==0){
        printf("list is empty!!\n");
        return;
    }
    for(int i=0; i<n; i++){
        printf("%d\n",list[i]);
    }
    printf("\n");
}
