#include<stdio.h>
int main(){
    int n;
    printf("enter array size: ");
    scanf("%d",&n);

    int arr[n];
    printf("enter array elements (sorted): ");
    for(int i=0; i<n; i++){
        scanf("%d", &arr[i]);
    }
    //selection sort
    for(int i=0; i<n-1; i++){
        int minIdx = i;
        for(int j = i+1; j<n; j++){
            if(arr[j]<arr[minIdx])
            minIdx = j;
        }
        if(minIdx != -1){
            int temp = arr[minIdx];
            arr[minIdx] = arr[i];
        }
    }
    printf("after sorting elements: ");
    for(int i=0; i<n; i++){
        printf("%d ",arr[i]);
    }
    return 0;
}
